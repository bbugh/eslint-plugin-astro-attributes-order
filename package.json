{
  "name": "eslint-plugin-astro-attributes-order",
  "version": "1.0.0",
  "description": "ESLint 9+ plugin to sort astro template attributes, inspired by vue/attributes-order.",
  "license": "MIT",
  "author": "Brian Bugh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbugh/eslint-plugin-astro-attributes-order.git"
  },
  "bugs": {
    "url": "https://github.com/bbugh/eslint-plugin-astro-attributes-order/issues"
  },
  "homepage": "https://github.com/bbugh/eslint-plugin-astro-attributes-order#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo --project tsconfig.build.json",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "astro-eslint-parser": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260504.1",
    "eslint": "^10.4.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "astro",
    "attributes-order"
  ]
}
